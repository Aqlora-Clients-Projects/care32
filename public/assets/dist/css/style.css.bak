    height: 250px;
    display: flex;
    justify-content: center;
    align-items: flex-end; /* To align doctor image at bottom */
    transition: background 0.3s ease;
}
.team-img-wrapper img {
    height: 100%;
    width: 100%;
    object-fit: cover;
}
/* Hover Card styling */
.team-card:hover .team-img-wrapper {
    background: linear-gradient(135deg, #ff8c00, #ff3c00); /* Orange gradient */
}

.team-info {
    position: relative;
    padding-right: 40px;
      transition: transform 0.3s ease, color 0.3s ease;
}
.team-name {
    font-size: 18px;
    font-weight: 700;
    color: #111;
    margin-bottom: 5px;
}
.team-specialty {
    font-size: 14px;
    color: #888;
    margin: 0;
}
.team-arrow {
    position: absolute;
    right: 0;
    bottom: 0;
    width: 32px;
    height: 32px;
    display: flex;
    justify-content: center;
    align-items: center;
    background-color: transparent;
    color: #111;
    font-size: 18px;
    transition: transform 0.3s ease, color 0.3s ease;
    cursor: pointer;
}
.team-card:hover .team-arrow {
    transform: translate(5px, -5px);
    color: var(--orange, #ff3c00);
}
.team-arrow i{
font-size: 30px;
}

.team-card:hover .team-info h4,
.team-card:hover .team-info p,
.team-card:hover .team-info i{
    color: white;
}

@media (max-width: 575px) {
    .team-main-title {
        font-size: 32px;
    }
}

/* =======================================
   Preloader Styles
======================================= */
#preloader {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--ui-bg, #1a1a1a); /* Adjust background color if needed */
    z-index: 99999;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: opacity 0.5s ease;
}

.preloader-content {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
}

.preloader-logo {
    width: 250px;
    max-width: 80vw;
    animation: pulse 1.5s infinite;
}

.spinner {
    width: 50px;
    height: 50px;
    border: 5px solid rgba(255, 255, 255, 0.1);
    border-top-color: #ff3c00;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

@keyframes pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.05); opacity: 0.8; }
    100% { transform: scale(1); opacity: 1; }
}
/* BOOKING SECTION STYLES */
.booking-section {
    /* background-color: #f8f9fa; */
    padding: 80px 0;
}
.booking-container-card {
    background-color: #ffffff;
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.03);
}
.booking-badge {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--orange);
    font-size: 14px;
    font-weight: 600;
    padding: 8px 16px;
    background: rgba(255, 95, 31, 0.1);
    border-radius: 50px;
    margin-bottom: 15px;
}
.booking-title {
    font-size: 42px;
    font-weight: 700;
    color: #111;
    line-height: 1.2;
}
.booking-desc {
    color: #666;
    font-size: 16px;
    line-height: 1.6;
    margin-top: 15px;
}
.booking-features li {
    font-size: 16px;
    color: #444;
    font-weight: 500;
    display: flex;
    align-items: center;
}
.booking-features i {
    font-size: 20px;
    color: var(--orange);
}
.booking-form-wrapper {
    background: white;
    border-radius: 20px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.05);
}
.booking-form .form-label {
    font-size: 14px;
    font-weight: 600;
    color: #333;
    margin-bottom: 8px;
}
.booking-form .form-control,
.booking-form .form-select {
    border-radius: 10px;
    border: 1px solid #e0e0e0;
    padding: 12px 15px;
    font-size: 15px;
    box-shadow: none;
    transition: all 0.3s ease;
}
.booking-form .form-control:focus,
.booking-form .form-select:focus {
    border-color: var(--orange);
    box-shadow: 0 0 0 3px rgba(255, 95, 31, 0.1);
}

.rowcard{
    background: white;
}

.adv-service-card {
    cursor: pointer;
}

.service-learn-more i {
    opacity: 0;
    transform: translateX(-10px);
    transition: all 0.3s ease;
    margin-left: 5px;
    display: inline-block;
}

.adv-service-card:hover .service-learn-more i,
.service-learn-more:hover i {
    opacity: 1;
    transform: translateX(0);
}
.team-card, .adv-service-card, .feature-card, .service-card, .card {
    cursor: pointer;
}

/* =======================================
   ADVANCED MOBILE RESPONSIVE TWEAKS 
======================================= */
@media (max-width: 991px) {
    .booking-container-card {
        padding: 30px 20px !important;
    }
    .booking-title, .services-main-title {
        font-size: 34px !important;
    }
}

@media (max-width: 767px) {
    /* General Typography & Spacing */
    h1 { font-size: 36px !important; line-height: 1.2 !important; }
    h2 { font-size: 28px !important; line-height: 1.3 !important; }
    p { font-size: 15px !important; }
    
    .booking-section, .custom-services-section, .team-section {
        padding: 50px 0 !important;
    }
    
    /* Services Grid */
    .adv-services-grid {
        grid-template-columns: 1fr !important;
        gap: 20px !important;
    }
    .adv-service-icon-wrapper {
        height: 180px !important;
    }

    /* Booking Form Card */
    .booking-container-card {
        padding: 20px 15px !important;
        border-radius: 15px !important;
    }
    .booking-form-wrapper {
        padding: 20px !important;
    }
    .booking-content-left {
        text-align: center;
        padding-right: 0 !important;
    }
    .booking-features li {
        justify-content: center;
        text-align: left;
    }
    
    /* Footer tweaks */
    .footer-bottom-watermark {
        font-size: 120px !important;
        bottom: -20px !important;
    }
    .footer-top {
        text-align: center;
    }
    .footer-headline h2 {
        font-size: 26px !important;
    }
    
    /* Teams Grid */
    .team-card {
        flex: 0 0 100% !important;
        margin-right: 0 !important;
        width: 100% !important;
    }
}

@media (max-width: 480px) {
    h1 { font-size: 30px !important; }
    h2 { font-size: 24px !important; }
    
    .footer-bottom {
        flex-direction: column;
        text-align: center;
    }
    .footer-bottom-links {
        margin-top: 15px;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
    }
    .footer-bottom-links a {
        margin: 5px 10px !important;
    }
    .footer-bottom-watermark {
        font-size: 90px !important;
        bottom: -10px !important;
    }
}

/* HIDE HORIZONTAL SCROLLBAR ON MOBILE */
html, body {
    overflow-x: hidden;
    max-width: 100vw;
}
/* HERO OVERRIDE */
.hero-massive-card::before {
    background: linear-gradient(135deg, rgba(0,0,0,0.7) 0%, rgba(255, 95, 31, 0.5) 100%) !important;
}
.hero-content-inner {
    position: relative;
    z-index: 2;
    text-shadow: 0 4px 15px rgba(0,0,0,0.5);
}

/* TEAM CARD OVERRIDE FIX */
.team-card {
    flex: 0 0 350px !important;
}
@media (max-width: 991px) {
    .team-card {
        flex: 0 0 320px !important;
    }
}

/* =======================================
   EXTREME MOBILE REDUCTION (320px - 600px)
======================================= */
@media (max-width: 600px) {
    /* Global Typography */
    h1, #hero-title, .booking-title, .services-main-title, .footer-headline h2, .team-main-title {
        font-size: 26px !important;
        line-height: 1.2 !important;
    }
    h2 { font-size: 22px !important; }
    h3 { font-size: 18px !important; }
    h4 { font-size: 16px !important; }
    p, #hero-desc, .adv-service-desc, .booking-desc, .team-specialty {
        font-size: 13px !important;
    }

    /* Padding & Spacing */
    .booking-section, .custom-services-section, .team-section, footer {
        padding: 40px 10px !important;
    }
    .dentora-hero{
           padding: 0px !important; 
    }
    .hero-massive-card {
        min-height: 60vh !important;
        border-radius: 20px !important;
        padding: 15px !important;
    }

    /* Card Reductions */
    .adv-service-card, .booking-container-card {
        padding: 15px !important;
        border-radius: 12px !important;
    }
    
    .team-card {
        flex: 0 0 280px !important; /* Smaller card for horizontal scroll */
        padding: 12px !important;
    }
    .team-img-wrapper {
        height: 160px !important;
        border-radius: 10px !important;
    }

    .adv-service-icon-wrapper {
        height: 140px !important; /* Shorter images for service cards */
    }

    /* Buttons & Links */
    .global-nav-btn, .btn, .service-learn-more, .hero-cta {
        padding: 10px 18px !important;
        font-size: 13px !important;
    }

    /* Footer */
    .footer-bottom-watermark {
        font-size: 50px !important;
        bottom: -5px !important;
    }
    
    /* Hero Tweaks */
    .hero-mini-card {
        padding: 10px !important;
        max-width: 250px !important;
        transform: scale(0.9) !important;
        transform-origin: left center !important;
    }
    .hero-tags-wrapper span {
        font-size: 11px !important;
        padding: 5px 10px !important;
    }
}

@media (max-width: 600px) {
 .global-nav-wrapper.navbar-home {
        background-color: #ffffff !important;
        /* border-radius: 25px !important; */
    }
    .global-nav-wrapper{
       border-radius: none !important;
    }
    .global-nav-wrapper.navbar-home .navbar-toggler {
    color: #000000 !important;
    margin-right: 20px;
}
#hero-desc,#hero-title {
    display: none;
}
#mobileMenuToggle i {
    transition: transform 0.3s ease;
}
.menu-open #mobileMenuToggle i {
    transform: rotate(90deg);
}

.fa-bars:before, .fa-navicon:before {
    content: "\f0c9";
    color: black;
}
.fa-close:before, .fa-multiply:before, .fa-remove:before, .fa-times:before, .fa-xmark:before {
    content: "\f00d";
    color: black;
}
.global-nav-wrapper {
        position: fixed !important;
        top: 0px !important;
        left: 0 !important;
        transform: none !important;
        width: 100% !important;
        border-radius: 0px !important;
    }
    .footer-bottom-watermark2 {
    font-size: 90px !important;
    }

}

@media(max-width:480px){
.footer-bottom-watermark2 {
    font-size: clamp(90px, 4vw, 120px) !important;
}
}


@media(max-width:400px){
.footer-bottom-watermark2 {
    font-size: clamp(60px, 4vw, 80px) !important;
}
    .newsletter-form{
        display: none !important;
    }
}
